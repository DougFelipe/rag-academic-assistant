# =================================================
# Environment Configuration - Distributed System
# =================================================
# Template for environment variables
# Copy to .env and replace placeholders with actual values
# NEVER commit .env to version control!

# =================================================
# DEPLOYMENT PROFILE
# =================================================
# Options: dev, test, prod
SPRING_PROFILES_ACTIVE=dev

# =================================================
# AI Service Configuration (Required)
# =================================================

# OpenAI API Key (or leave empty and use Ollama instead)
# Get it at: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# AI Model Selection for OpenAI
# Options: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
AI_MODEL=gpt-4-turbo-preview

# Enable/disable AI features
AI_ENABLED=true

# Ollama Local Configuration (Alternative to OpenAI for development)
# Install from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# =================================================
# Database Configuration (PostgreSQL)
# =================================================

# Host and port
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database and credentials
POSTGRES_DB=distribuida_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# =================================================
# Cache Configuration (Redis)
# =================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =================================================
# Message Queue Configuration (RabbitMQ)
# =================================================

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# =================================================
# Service Discovery Configuration (Eureka)
# =================================================

EUREKA_URL=http://localhost:8761/eureka

# =================================================
# External APIs (Optional)
# =================================================

# GitHub API Token
# Get it at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# News API Key
# Get it at: https://newsapi.org
NEWS_API_KEY=

# OpenWeather Map API Key
# Get it at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# =================================================
# Security Configuration
# =================================================

# JWT Secret (generate with strong random string)
# Min 256 bits recommended for production
JWT_SECRET=

# JWT Token Expiration (milliseconds)
JWT_EXPIRATION=3600000

# =================================================
# Monitoring & Observability (Optional)
# =================================================

# Prometheus Push Gateway
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091

# Grafana (if running observability stack)
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# Zipkin (Distributed Tracing)
ZIPKIN_URL=http://localhost:9411/api/v2/spans

# =================================================
# Development Notes
# =================================================
# 1. For local development: use Ollama (free) instead of OpenAI
# 2. Generate secure passwords: openssl rand -base64 32
# 3. Keep sensitive data in .env (not in version control)
# 4. .env is automatically ignored by .gitignore
# 5. All empty values are optional and have sensible defaults
